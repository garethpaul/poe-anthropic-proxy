# Poe API Configuration
POE_API_KEY=your_poe_api_key_here
POE_BASE_URL=https://api.poe.com
POE_MODEL=Claude-Sonnet-4

# Caller authentication for this proxy.
# Send requests with: Authorization: Bearer your_proxy_bearer_token_here
PROXY_AUTH_TOKEN=your_proxy_bearer_token_here
# Local-only escape hatch. Do not enable for public deployments.
ALLOW_UNAUTHENTICATED_PROXY=false

# Server Configuration
PORT=3000
DEBUG=false
