{
  "name": "poe-anthropic-bridge",
  "version": "1.0.0",
  "description": "Bridge between Anthropic Messages API and Poe API",
  "main": "poe-proxy.js",
  "type": "module",
  "scripts": {
    "start": "node poe-proxy.js",
    "dev": "node --watch poe-proxy.js",
    "lint": "node --check poe-proxy.js",
    "test": "node --test",
    "build": "node --check poe-proxy.js",
    "audit": "npm audit --audit-level=moderate",
    "verify": "npm run lint && npm test && npm run build && npm run audit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5"
  },
  "keywords": [
    "anthropic",
    "poe",
    "api",
    "proxy",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
